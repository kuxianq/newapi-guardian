# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
AUTHORIZED_TELEGRAM_IDS=123456789,987654321

# MySQL (只读用户)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=newapi_guardian
MYSQL_PASSWORD=your_password_here_here
MYSQL_DATABASE=newapi

# NewAPI
NEWAPI_BASE_URL=http://localhost:3000
NEWAPI_ADMIN_TOKEN=your_admin_token_here_here
NEWAPI_ADMIN_USER_ID=1

# 备份（可选）
MYSQL_ROOT_PASSWORD=your_root_password_here
BACKUP_DIR=/path/to/backups

# 监控参数（可选）
CHECK_INTERVAL_MINUTES=10
ALERT_CONSECUTIVE_FAILURES=3
ALERT_COOLDOWN_MINUTES=30
DAILY_REPORT_HOUR=9

# AI 配置（可选）
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4
