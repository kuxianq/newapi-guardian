# MySQL / NewAPI database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=newapi_guardian
MYSQL_PASSWORD=replace-me
MYSQL_DATABASE=newapi

# NewAPI admin API
NEWAPI_BASE_URL=http://127.0.0.1:3000
